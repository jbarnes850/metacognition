# Copy this file to your shell profile or source it before running experiments.
# Paths may point to directories, symlinks, or Hugging Face snapshot folders.

# Shared default for repo-relative model paths used by the MLX runners.
export METACOG_MODEL_ROOT="$PWD/models"

# Qwen3.5 dense models used by sweep_fullpool.py, probe.py, and varentropy_test.py.
export METACOG_QWEN35_08B_PATH="$METACOG_MODEL_ROOT/Qwen3.5-0.8B"
export METACOG_QWEN35_2B_PATH="$METACOG_MODEL_ROOT/Qwen3.5-2B"
export METACOG_QWEN35_4B_PATH="$METACOG_MODEL_ROOT/Qwen3.5-4B"
export METACOG_QWEN35_9B_PATH="$METACOG_MODEL_ROOT/Qwen3.5-9B"

# Quantized MLX checkpoints used by social_source_monitoring.py.
export METACOG_QWEN36_35B_A3B_PATH="$METACOG_MODEL_ROOT/qwen3.6-35b-a3b-mlx-int6"
export METACOG_GEMMA4_E4B_IT_PATH="$METACOG_MODEL_ROOT/gemma-4-E4B-it-mlx-int6"
export METACOG_GEMMA4_26B_A4B_IT_PATH="$METACOG_MODEL_ROOT/gemma-4-26b-a4b-it-mlx-int6"

# Transformers or SGLang Qwen3.6 scripts.
export QWEN_MODEL_PATH="$METACOG_MODEL_ROOT/qwen3.6-35b-a3b"
export QWEN_OUTPUT_DIR="$PWD/results/qwen36"
